doctype html
html
  head
    link(rel="shortcut icon" type="image/png" href="/images/icons/favicon.png")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    style.
      .sheet {
        margin: 0;
        width: 100%; 
        height: 297mm;
      }
      body {
        width: 100%; 
        margin: 0;
        padding: 0px;
        background: #ffffff;
        font-family: sans-serif;
        font-size: 12px;
        color: #222;
      }
      *, *:before, *:after {
        box-sizing: inherit;
        color: #222;
      }
      .clearfix {
        display: block;
      }
      .left {
        float: left;
      }
      .right {
        float: right;
      }
      .top-area {    
        display: block;
        width: 100%;
        margin-bottom: 20px;
      }
      .logo {
        width: 180px;
        max-height: 80px;
        object-fit: contain;
      }
      .company-info {
        text-align: right;
        font-size: 12px;
        line-height: 1.5;
      }
      h1.po {
        font-size: 28px;
        color: #0A1528; /* KCC Dark Navy */
        font-weight: 800;
        margin-top: 0;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
      }
      p.strong {
        font-weight: 700;
        color: #0A1528; /* KCC Dark Navy */
      }
      .billTo p, .shipTo p {
        text-align: left !important;
        float: left;
        display: block;
        font-size: 12px;
        width: 100%;
        margin-top: 0;
        margin-bottom: 5px;
      }
      .col {
        float: left;
      }
      .col-1 { width: 4.16667%; }
      .col-2 { width: 8.33333%; }
      .col-3 { width: 12.5%; }
      .col-4 { width: 16.66667%; }
      .col-5 { width: 20.83333%; }
      .col-6 { width: 25%; }
      .col-7 { width: 29.16667%; }
      .col-8 { width: 33.33333%; }
      .col-9 { width: 37.5%; }
      .col-10 { width: 41.66667%; }
      .col-11 { width: 45.83333%; }
      .col-12 { width: 50%; }
      .col-13 { width: 54.16667%; }
      .col-14 { width: 58.33333%; }
      .col-15 { width: 62.5%; }
      .col-16 { width: 66.66667%; }
      .col-17 { width: 70.83333%; }
      .col-18 { width: 75%; }
      .col-19 { width: 79.16667%; }
      .col-20 { width: 83.33333%; }
      .col-21 { width: 87.5%; }
      .col-22 { width: 91.66667%; }
      .col-23 { width: 95.83333%; }
      .col-24 { width: 100%; }
      .space {
        margin-top: 20px;
        margin-bottom: 20px;
        width: 100%;
        clear: both;
      }
      
      /* TABLE STYLING - KCC BRANDING */
      .table-po {
        width: 100%;
        border-collapse: collapse;
        border-spacing: 0;
        margin-bottom: 20px;
        border: 1px solid #0A1528;
      }
      .table-po tr:nth-child(2n-1) td {
        background: #f9f9f9;
      }
      .table-po th {
        padding: 10px 10px;
        background-color: #0A1528; /* KCC Dark Navy Background */
        color: #C9A567; /* KCC Gold Text */
        white-space: nowrap;
        font-weight: 700;
        font-size: 12px;
        text-align: right;
        border-bottom: 2px solid #C9A567; /* Gold Border */
      }
      .table-po td {
        padding: 10px;
        text-align: right;
        font-size: 11px;
        border-bottom: 1px solid #eee;
        color: #333;
      }
      .table-po .material {
        text-align: left;
      }
      .table-po th:first-child, .table-po td.material {
        text-align: left;
      }
      
      /* Material Details */
      .material span {
        display: block;
        width: 100%;
        color: #666;
        margin-top: 3px;
        font-size: 10px;
      }

      /* Totals Section */
      .table-po td.grand {
        border-top: 2px solid #0A1528;
        color: #0A1528;
      }
      
      /* Footer & Terms */
      .terms-box {
        margin-top: 20px;
        padding: 15px;
        border: 1px solid #ddd;
        border-left: 4px solid #C9A567; /* Gold Accent */
        background: #fafafa;
        font-size: 11px;
        color: #555;
      }
      .signature-box {
        margin-top: 50px;
        padding: 0px;
        width: 250px;
        float: right;
        text-align: center;
      }
      .signature-line {
        border-bottom: 1px solid #0A1528;
        margin-bottom: 5px;
        height: 40px;
      }
      .footer-po {
        width: 100%;
        position: fixed;
        bottom: 0;
        left: 0;
        padding: 10px 0;
        text-align: center;
        font-size: 10px;
        color: #999;
        background: #fff;
        border-top: 1px solid #eee;
      }
      
      /* Label Coloring */
      .label-gold {
        color: #C9A567; /* Gold Color for Labels if needed */
        font-weight: 600;
      }

  body
    header.clearfix
      .top-area
        //- LOGO SECTION: Uses settings logo
        if settings.company_logo
            img.logo.left(src=settings.public_server_file+settings.company_logo)
        
        .right.company-info
            p.strong(style="font-size: 16px; color: #0A1528") #{settings.company_name}
            p #{settings.company_address}
            p #{settings.company_email}
            if settings.company_reg_number
                p GST/Reg: #{settings.company_reg_number}
            
      .col.col-24
        .space(style="border-bottom: 2px solid #0A1528; margin-top: 10px; margin-bottom: 30px;")  
     
      .left.col-14
          h1.po Purchase Order
          div 
            .col.col-7
              p.strong PO Date :
              p #{moment(model.date).format(dateFormat)}
            .col.col-9
              p.strong Expected Delivery :
              p #{model.expectedDeliveryDate ? moment(model.expectedDeliveryDate).format(dateFormat) : 'N/A'}
            .col.col-8 
              p.strong PO Number :
              p(style="color: #C9A567; font-weight: bold;") PO-#{model.year || ""}-#{String(model.number || "").padStart(4, '0')}
            .col.col-8
              p.strong Status :
              p #{model.status || 'Draft'}
              
      .right.col-10
          .billTo
              p.strong(style="background: #0A1528; color: #fff; padding: 2px 5px; display: inline-block; margin-bottom: 8px;") Vendor Details:
              p.strong #{model.supplier ? (model.supplier.name || 'N/A') : 'N/A'}
              p #{model.supplier ? (model.supplier.address || '') : ''}
              p Phone: #{model.supplier ? (model.supplier.phone || 'N/A') : 'N/A'}
              p Email: #{model.supplier ? (model.supplier.email || 'N/A') : 'N/A'}
          .shipTo(style="margin-top: 15px")
              p.strong(style="background: #0A1528; color: #fff; padding: 2px 5px; display: inline-block; margin-bottom: 8px;") Ship To:
              p.strong #{settings.company_name}
              p #{settings.company_address}
              p Contact: #{settings.company_phone || 'N/A'}
        
      .col.col-24
          .space  
    main
      table.table-po
        thead
          tr.tableHeader
            th(style="width: 5%; text-align: left") #
            th.material(style="width: 35%") Item & Description
            th(style="width: 10%") Unit
            th(style="width: 12%") Qty
            th(style="width: 15%") Rate
            th(style="width: 18%") Amount
        tbody
          each item, index in model.items
            tr
              td(style="text-align: left") #{index + 1}
              td.material 
                strong(style="color: #0A1528") #{item.material ? (item.material.name || 'Unknown Material') : 'Unknown Material'}
                if item.material && item.material.code
                  span Code: #{item.material.code}
                if item.material && item.material.category
                  span Category: #{item.material.category}
              td.unit #{item.material ? (item.material.uom || item.material.unit || 'nos') : 'nos'}
              td.qty #{item.quantity || 0}
              td.unit #{moneyFormatter({amount:item.rate || 0})}
              td.total(style="font-weight: 600") #{moneyFormatter({amount:item.amount || 0})}
          
          //- Empty rows if needed or just spacing
          
          tr
            td(colspan='5', style="text-align: right; font-weight: bold; color: #555") Sub Total
            td.total(style="font-weight: bold") #{moneyFormatter({amount:model.subTotal || 0})}
          
          if model.taxRate && model.taxRate > 0
            tr
              td(colspan='5', style="text-align: right; font-weight: bold; color: #555") Tax (#{model.taxRate}%)
              td.total(style="font-weight: bold") #{moneyFormatter({amount:model.taxTotal || 0})}
          
          tr
            td.grand.total(colspan='5', style="text-align: right; font-weight: 800; font-size: 14px; color: #0A1528") GRAND TOTAL
            td.grand.total(style="font-weight: 800; font-size: 14px; background: #f0f2f5; color: #0A1528") #{moneyFormatter({amount:model.totalAmount || 0})}
      
    .col.col-24
       .space     
    
    .terms-box
        p.strong(style="color: #0A1528; text-decoration: underline") Terms & Conditions:
        if model.termsAndConditions
            p(style="white-space: pre-wrap;") #{model.termsAndConditions}
        else if model.terms
            p(style="white-space: pre-wrap;") #{model.terms}
        else
            p 1. Please send two copies of your invoice.
            p 2. Enter this order in accordance with the prices, terms, delivery method, and specifications listed above.
            p 3. Please notify us immediately if you are unable to ship as specified.
    
    .signature-box
      .signature-line
      p.strong Authorized Signatory
      p(style="font-size: 10px; color: #888;") For #{settings.company_name}
    
    footer.footer-po
      | This is a computer-generated document and is valid without a physical signature.